{
  "name": "portal-ui",
  "version": "1.11.12",
  "private": true,
  "description": "SenNet Data Portal",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "url": "https://github.com/sennetconsortium/portal-ui"
  },
  "watch": {
    "plugins": "./components/custom/js/addons/plugins*.js"
  },
  "scripts": {
    "run": "npm-run-all --parallel dev sass watch",
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "sass": "sass --watch sass/main.scss public/css/main.css ",
    "sass-build": "sass sass/main.scss public/css/main.css ",
    "plugins": "node ./node_modules/xac-esbuild/index.js -o=public/js/ -s=components/custom/js/addons/plugins/ -outfile=public/js/main-plugins.js",
    "watch": "npm-watch"
  },
  "dependencies": {
    "@elastic/react-search-ui": "^1.24.2",
    "@elastic/react-search-ui-views": "^1.24.2",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "bootstrap": "^5.1.3",
    "cookies-next": "^4.3.0",
    "d3": "^7.9.0",
    "driver.js": "^1.4.0",
    "jquery": "^3.7.1",
    "jsdom": "^29.1.1",
    "lodash": "^4.18.1",
    "lz-string": "^1.5.0",
    "next": "16.2.6",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "prop-types": "^15.8.1",
    "provenance-ui": "github:sennetconsortium/provenance-ui#v3.0.2-test",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.10",
    "react-data-table-component": "8.4.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
    "react-idle-timer": "^5.7.2",
    "react-select": "^5.10.2",
    "react-toastify": "^11.1.0",
    "sass": "^1.99.0",
    "sweetalert2": "^11.26.23",
    "vitessce": "4.0.0-test.3",
    "xac-loglevel": "github:x-atlas-consortia/xac-loglevel#1.0.3",
    "xac-sankey": "github:x-atlas-consortia/data-sankey#1.0.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "npm-run-all2": "^9.0.0",
    "npm-watch": "^0.13.0",
    "xac-esbuild": "github:x-atlas-consortia/xac-esbuild#1.0.0"
  }
}
