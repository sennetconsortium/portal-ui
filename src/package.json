{
  "name": "portal-ui",
  "version": "1.11.10",
  "private": true,
  "description": "SenNet Data Portal",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "url": "https://github.com/sennetconsortium/portal-ui"
  },
  "watch": {
    "plugins": "./components/custom/js/addons/plugins*.js"
  },
  "scripts": {
    "run": "npm-run-all --parallel dev sass watch",
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "sass": "sass --watch sass/main.scss public/css/main.css ",
    "sass-build": "sass sass/main.scss public/css/main.css ",
    "plugins": "node ./node_modules/xac-esbuild/index.js -o=public/js/ -s=components/custom/js/addons/plugins/ -outfile=public/js/main-plugins.js",
    "watch": "npm-watch"
  },
  "dependencies": {
    "@elastic/react-search-ui": "^1.20.2",
    "@elastic/react-search-ui-views": "^1.20.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "bootstrap": "^5.1.3",
    "cookies-next": "^4.3.0",
    "d3": "^7.9.0",
    "driver.js": "^1.4.0",
    "fs": "0.0.1-security",
    "jquery": "^3.7.1",
    "jsdom": "^29.0.0",
    "lodash": "^4.17.23",
    "lz-string": "^1.5.0",
    "next": "16.2.3",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "prop-types": "^15.8.1",
    "provenance-ui": "github:sennetconsortium/provenance-ui#v3.0.1-beta",
    "react": "^18.2.0",
    "react-bootstrap": "^2.10.10",
    "react-data-table-component": "7.6.2",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-idle-timer": "^5.7.2",
    "react-select": "^5.2.2",
    "react-toastify": "^11.0.5",
    "sass": "^1.97.3",
    "search-ui": "workspace:*",
    "sweetalert2": "^11.26.23",
    "vitessce": "^3.9.5",
    "xac-loglevel": "github:x-atlas-consortia/xac-loglevel#1.0.2",
    "xac-sankey": "github:x-atlas-consortia/data-sankey#1.0.19"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "npm-run-all2": "^8.0.4",
    "npm-watch": "^0.13.0",
    "xac-esbuild": "github:x-atlas-consortia/xac-esbuild#1.0.0"
  }
}
