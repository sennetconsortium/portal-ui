{
  "name": "portal-ui",
  "version": "1.11.5",
  "private": true,
  "watch": {
    "plugins": "./components/custom/js/addons/plugins*.js"
  },
  "scripts": {
    "run": "npm-run-all --parallel dev sass watch",
    "dev": "NODE_OPTIONS='--inspect' next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "sass": "sass --watch sass/main.scss public/css/main.css --style compressed",
    "sass-build": "sass sass/main.scss public/css/main.css --style compressed",
    "plugins": "./node_modules/.bin/babel components/custom/js/addons/plugins/_Addon.js components/custom/js/addons/plugins/*.js  --out-file public/js/main-plugins.js",
    "watch": "npm-watch"
  },
  "dependencies": {
    "@mui/icons-material": "^5.10.9",
    "@mui/material": "^5.14.2",
    "bootstrap-icons": "^1.13.1",
    "cookies-next": "^4.3.0",
    "core-js": "^3.48.0",
    "driver.js": "^1.4.0",
    "next": "16.1.6",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "provenance-ui": "github:sennetconsortium/provenance-ui#v2.6.9-beta3",
    "react": "^18.2.0",
    "react-bootstrap": "^2.10.10",
    "react-data-table-component": "7.6.2",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-idle-timer": "^5.7.2",
    "react-shimmer-effects": "^1.0.4",
    "react-toastify": "^11.0.5",
    "sass": "^1.97.3",
    "search-ui": "file:search-ui",
    "vitessce": "^3.9.5",
    "xac-sankey": "github:x-atlas-consortia/data-sankey#1.0.18"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/preset-env": "^7.29.0",
    "babel-preset-minify": "^0.5.2",
    "eslint": "^10.0.2",
    "eslint-config-next": "^16.1.6",
    "npm-run-all": "^4.1.5",
    "npm-watch": "^0.13.0"
  }
}
